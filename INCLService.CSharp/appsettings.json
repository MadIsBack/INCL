{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.File", "Serilog.Sinks.RollingFile"],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "RollingFile",
        "Args": {
          "pathFormat": "LOG\\svc_{0}_trace.log",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} : {Message}{NewLine:1}",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 4194304
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Database": {
    "DB_Server": "includis.world",
    "InitialCatalog": "includis",
    "DB_User": "INCLUDIS",
    "DB_Pass": "comtas",
    "Provider": ""
  },
  "Main": {
    "Home": "d:\\comtas\\",
    "Timer": 15,
    "AliveTimerInterval": 15,
    "IgnorePending": true
  },
  "Features": {
    "Pruefen": false,
    "Packen": false,
    "VerpacktBarcode": false,
    "VerpacktAusAusschuss": false,
    "EndeAusVerpackt": false,
    "BCDSchalter": false,
    "SPC": false,
    "SPCStich": false,
    "Halbautomatik": false,
    "PruefGleichPack": false,
    "Werkzeugverwaltung": false,
    "Maschinenreinigung": false,
    "WerkstattAusschuss": false,
    "Differenzliste": false,
    "RuntimeLog": false,
    "RuestzeitAuftragFolgeAuftrag": false
  },
  "Shift": {
    "Priority": 3,
    "Timer": 60
  },
  "DBBackup": {
    "Priority": 4,
    "Timer": 60,
    "Path": "d:\\comtas\\backup\\"
  },
  "Signallog": {
    "Priority": 3,
    "Timer": 30
  },
  "Addons": {
    "Priority": 4,
    "Timer": 600
  }
}
